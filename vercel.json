{
  "builds": [
    {
      "src": "api.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 300 }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",       "dest": "api.py" },
    { "src": "/analyze",        "dest": "api.py" },
    { "src": "/webhooks/(.*)",  "dest": "api.py" },
    { "src": "/health",         "dest": "api.py" },
    { "src": "/(.*)",           "dest": "frontend/$1" }
  ]
}
